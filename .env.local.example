# ─── HOLALA Cuban Flavor — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Get from: https://sanity.io → Your Project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# ─── GA4 ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.holalacubanflavor.com

# ─── Resend (email notifications) ───────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Domain holalacubanflavor.com must be verified in Resend first:
#   Resend → Domains → Add Domain → copy TXT + CNAME records → add in Cloudflare
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must match the verified sending domain (e.g. noreply@holalacubanflavor.com)
RESEND_FROM_EMAIL=noreply@holalacubanflavor.com

# ─── Square POS (Sprint 2) ───────────────────────────────────────────────────
# NOT used by Next.js/Vercel — these configure the Supabase Edge Function
# `supabase/functions/square-webhook`. Set them with `supabase secrets set`,
# never in Vercel env vars. Documented here so all project credentials live
# in one place.
#
# Get from: https://developer.squareup.com -> Apps -> [app] -> Credentials
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=sandbox

# Get from: Square Developer Dashboard -> Webhooks -> Subscriptions -> Signature key
SQUARE_WEBHOOK_SIG_KEY=your-webhook-signature-key

# Must match the URL registered as the webhook subscription endpoint
SQUARE_WEBHOOK_NOTIFICATION_URL=https://rqpfqxmohdttghscoknh.supabase.co/functions/v1/square-webhook

# Holala Cuban Flavors main location (from Square Locations API)
SQUARE_LOCATION_ID=LHDV14TEF3QMK
